NEXT_PUBLIC_APP_URL=http://localhost:3000

# The root url of the API server
VITE_APP_API_ROOT_URL

# IDE CLIENT VARIABLES
VITE_APP_SERVER_PORT
VITE_APP_NODE_ENV
VITE_APP_DEFAULT_PROJECT_ID
VITE_APP_DEFAULT_USER_ID
